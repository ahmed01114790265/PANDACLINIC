@using PANDACLINIC.Application.DTOS.Animal
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model AnimalSummaryDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5 text-center">
                    <h2 class="mb-3">@Localizer["Title"]</h2>
                    <p class="text-muted mb-4">@Localizer["Selected", Model.Name]</p>

                    <div class="alert alert-info">
                        @Localizer["Info"]
                    </div>

                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a class="btn btn-primary" asp-controller="Appointment" asp-action="Create" asp-route-animalId="@Model.Id">@Localizer["GoToAppointment"]</a>
                        <a class="btn btn-outline-secondary" asp-action="MyAnimals">@Localizer["Back"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
