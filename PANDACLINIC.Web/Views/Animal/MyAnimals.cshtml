@using PANDACLINIC.Application.DTOS.Animal
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<AnimalSummaryDto>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">@Localizer["Title"]</h2>
            <p class="text-muted">@Localizer["Subtitle"]</p>
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> @Localizer["Add"]
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var animal in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <img src="@(string.IsNullOrEmpty(animal.Imgageurl) ? "/images/default-pet.png" : animal.Imgageurl)"
                             class="card-img-top" alt="@animal.Name"
                             style="height: 200px; object-fit: cover;">

                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">@animal.Name</h5>
                            <button type="button"
                                    class="btn btn-sm btn-primary select-service-btn"
                                    data-animal-id="@animal.Id"
                                    data-animal-name="@animal.Name"
                                    data-bs-toggle="modal"
                                    data-bs-target="#serviceChoiceModal">
                                @Localizer["ChooseService"]
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">@Localizer["Empty"]</div>
        }
    </div>
</div>

<div class="modal fade" id="serviceChoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["ModalTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="mb-3">@Localizer["Selected"] <strong id="selectedAnimalName"></strong></p>
                <div class="d-grid gap-2">
                    <a id="appointmentLink" class="btn btn-primary">@Localizer["BookAppointment"]</a>
                    <a id="hostingLink" class="btn btn-outline-secondary">@Localizer["BookHosting"]</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.select-service-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var animalId = btn.getAttribute('data-animal-id');
                var animalName = btn.getAttribute('data-animal-name');

                document.getElementById('selectedAnimalName').textContent = animalName;
                document.getElementById('appointmentLink').href = '/Appointment/Create?animalId=' + animalId;
                document.getElementById('hostingLink').href = '/Hosting/Create?animalId=' + animalId;
            });
        });
    </script>
}
