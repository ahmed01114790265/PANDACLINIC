@using PANDACLINIC.Application.DTOS.Order
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model OrderDetailDto

<div class="container py-4">
    <h2 class="fw-bold mb-4">@Localizer["Title"]</h2>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p><strong>@Localizer["Invoice"]</strong> <span class="badge bg-light text-dark border">#@Model.Id</span></p>
                    <p><strong>@Localizer["Date"]</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                    <p><strong>@Localizer["Client"]</strong> @Model.ClientName</p>
                    <p><strong>@Localizer["Phone"]</strong> @Model.ClientPhone</p>
                    <p><strong>@Localizer["Address"]</strong> @Model.ClientAddress</p>
                    <p><strong>@Localizer["PaymentMethod"]</strong> @Model.PaymentMethod</p>
                    <p><strong>@Localizer["PaymentStatus"]</strong> @Model.PaymentStatus</p>
                    <p><strong>@Localizer["Status"]</strong> @Model.Status</p>
                    <p><strong>@Localizer["Total"]</strong> @Model.TotalAmount.ToString("0.##") @Localizer["Currency"]</p>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">@Localizer["Products"]</h5>
                    <table class="table">
                        <thead>
                            <tr><th>@Localizer["Product"]</th><th>@Localizer["Quantity"]</th><th>@Localizer["UnitPrice"]</th><th>@Localizer["Total"]</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("0.##")</td>
                                    <td>@item.LineTotal.ToString("0.##")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
