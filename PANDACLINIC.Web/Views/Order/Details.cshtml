@using PANDACLINIC.Application.DTOS.Order
@model OrderDetailDto

<div class="container py-4">
    <h2 class="fw-bold mb-4">تفاصيل الطلب</h2>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p><strong>رقم الفاتورة:</strong> <span class="badge bg-light text-dark border">#@Model.Id</span></p>
                    <p><strong>التاريخ:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                    <p><strong>العميل:</strong> @Model.ClientName</p>
                    <p><strong>الهاتف:</strong> @Model.ClientPhone</p>
                    <p><strong>العنوان:</strong> @Model.ClientAddress</p>
                    <p><strong>طريقة الدفع:</strong> @Model.PaymentMethod</p>
                    <p><strong>حالة الدفع:</strong> @Model.PaymentStatus</p>
                    <p><strong>حالة الطلب:</strong> @Model.Status</p>
                    <p><strong>الإجمالي:</strong> @Model.TotalAmount.ToString("0.##") جنيه</p>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">المنتجات</h5>
                    <table class="table">
                        <thead>
                            <tr><th>المنتج</th><th>الكمية</th><th>سعر الوحدة</th><th>الإجمالي</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("0.##")</td>
                                    <td>@item.LineTotal.ToString("0.##")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
