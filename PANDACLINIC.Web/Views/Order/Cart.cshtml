@using PANDACLINIC.Application.DTOS.Order
@model IEnumerable<OrderItemSummaryDto>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">سلة المشتريات</h2>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">متابعة التسوق</a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>المنتج</th>
                        <th>الكمية</th>
                        <th>سعر الوحدة</th>
                        <th>الإجمالي</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>
                                <form asp-action="UpdateCart" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="quantity" min="0" value="@item.Quantity" class="form-control" style="max-width:100px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">تحديث</button>
                                </form>
                            </td>
                            <td>@item.UnitPrice.ToString("0.##")</td>
                            <td>@item.LineTotal.ToString("0.##")</td>
                            <td>
                                <form asp-action="RemoveFromCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <h4>الإجمالي: @(((decimal)ViewBag.Total).ToString("0.##")) جنيه</h4>
            <a asp-action="Checkout" class="btn btn-primary btn-lg">إتمام الطلب</a>
        </div>
    }
    else
    {
        <div class="alert alert-info">السلة فارغة.</div>
    }
</div>
