@using PANDACLINIC.Application.DTOS.Product
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<ProductSummaryDto>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">@Localizer["Title"]</h2>
        <a asp-controller="Order" asp-action="Cart" class="btn btn-outline-primary">@Localizer["ViewCart"]</a>
    </div>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="@Localizer["SearchPlaceholder"]" />
        </div>
        <div class="col-md-4">
            <select name="type" class="form-select" asp-items="Html.GetEnumSelectList<ProductType>()">
                <option value="">@Localizer["AllTypes"]</option>
            </select>
        </div>
        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-primary">@Localizer["Filter"]</button>
        </div>
    </form>

    <div class="row g-3">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                var finalPrice = item.Price;
                if (item.DiscountPercentage.HasValue && item.DiscountPercentage.Value > 0)
                {
                    finalPrice -= finalPrice * item.DiscountPercentage.Value / 100m;
                }

                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/uploads/default-product.png" : item.ImageUrl)" class="card-img-top" style="height:220px;object-fit:cover;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text text-muted mb-2">@item.Description</p>
                            <div class="mb-2">
                                <span class="fw-bold">@Localizer["Price"]:</span>
                                <span class="text-primary">@finalPrice.ToString("0.##")</span>
                                @if (item.DiscountPercentage.HasValue && item.DiscountPercentage.Value > 0)
                                {
                                    <span class="badge bg-success ms-2">@Localizer["Discount", item.DiscountPercentage]</span>
                                }
                            </div>
                            <span class="badge bg-secondary align-self-start">@item.Type.ToString()</span>
                            <div class="mt-auto pt-2">
                                <a asp-controller="Order" asp-action="AddToCart" asp-route-productId="@item.Id" class="btn btn-primary w-100">@Localizer["AddToCart"]</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">@Localizer["NoProducts"]</div>
            </div>
        }
    </div>
</div>
