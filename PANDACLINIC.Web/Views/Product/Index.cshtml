@using PANDACLINIC.Application.DTOS.Product
@using PANDACLINIC.Shared.Enums
@model IEnumerable<ProductSummaryDto>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">المنتجات</h2>
        <a asp-controller="Order" asp-action="Cart" class="btn btn-outline-primary">عرض السلة</a>
    </div>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="ابحث عن منتج" />
        </div>
        <div class="col-md-4">
            <select name="type" class="form-select" asp-items="Html.GetEnumSelectList<ProductType>()">
                <option value="">كل الأنواع</option>
            </select>
        </div>
        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-primary">فلترة</button>
        </div>
    </form>

    <div class="row g-3">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                var finalPrice = item.Price;
                if (item.DiscountPercentage.HasValue && item.DiscountPercentage.Value > 0)
                {
                    finalPrice -= finalPrice * item.DiscountPercentage.Value / 100m;
                }

                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/uploads/default-product.png" : item.ImageUrl)" class="card-img-top" style="height:220px;object-fit:cover;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="text-muted small mb-1">@item.Type</p>
                            <p class="card-text small text-secondary">@item.Description</p>
                            <p class="fw-bold text-primary mb-2">@finalPrice.ToString("0.##") جنيه</p>
                            <p class="small text-muted">المخزون: @item.Stock</p>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary w-100">التفاصيل</a>
                                <a asp-controller="Order" asp-action="AddToCart" asp-route-productId="@item.Id" asp-route-quantity="1" class="btn btn-primary w-100">أضف للسلة</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">لا توجد منتجات متاحة حالياً.</div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    (function() {
        var typeSelect = document.querySelector('select[name="type"]');
        var selected = '@(ViewBag.Type?.ToString() ?? string.Empty)';
        if (typeSelect && selected) typeSelect.value = selected;
    })();
</script>
}

