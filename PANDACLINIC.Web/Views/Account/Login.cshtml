@model PANDACLINIC.Web.Models.AccountViewModel.LoginPhoneVM

@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-3">تسجيل الدخول</h2>
                    <p class="text-center text-muted mb-4">ادخل برقم الهاتف وكلمة المرور</p>

                    @if (ViewBag.PendingAddToCart == true)
                    {
                        <div class="alert alert-info">بعد تسجيل الدخول سيتم إضافة المنتج إلى السلة تلقائيًا.</div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">رقم الهاتف</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="01xxxxxxxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">كلمة المرور</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="RememberMe" />
                            <label class="form-check-label" asp-for="RememberMe">تذكرني</label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">دخول</button>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-action="Register" class="text-decoration-none">ليس لديك حساب؟ أنشئ حسابًا جديدًا</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
