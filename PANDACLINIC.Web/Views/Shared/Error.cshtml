@model ErrorViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"];
}

<h1 class="text-danger">@Localizer["Title"]</h1>
<h2 class="text-danger">@Localizer["Message"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@Localizer["RequestIdLabel"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@Localizer["DevModeTitle"]</h3>
<p>@Localizer["DevModeText"]</p>
<p>@Localizer["DevWarning"]</p>
