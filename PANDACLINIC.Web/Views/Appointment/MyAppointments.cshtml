@using PANDACLINIC.Application.DTOS.Appointment
@using PANDACLINIC.Shared.Enums
@model IEnumerable<AppointmentSummaryDto>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div dir="rtl">
            <h2 class="fw-bold text-primary mb-1">مواعيدي</h2>
            <p class="text-muted">جميع مواعيد الحيوانات الخاصة بك</p>
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> حجز موعد جديد
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>الحيوان</th>
                        <th>النوع</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th class="text-end">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.AnimalName</td>
                                <td>@item.TypeOfAppoinment</td>
                                <td>
                                    <span class="badge @(item.Status == AppointmentStatus.Scheduled ? "bg-warning text-dark" : item.Status == AppointmentStatus.Completed ? "bg-success" : "bg-danger")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>@item.AppointmentDate.ToString("yyyy-MM-dd hh:mm")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this appointment?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">لا يوجد مواعيد حالياً.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
