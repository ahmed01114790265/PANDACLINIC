@using PANDACLINIC.Application.DTOS.Appointment
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<AppointmentSummaryDto>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">@Localizer["Title"]</h2>
            <p class="text-muted">@Localizer["Subtitle"]</p>
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> @Localizer["Add"]
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Pet"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Date"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.AnimalName</td>
                                <td>@Localizer[item.TypeOfAppoinment.ToString()]</td>
                                <td>
                                    <span class="badge @(item.Status == AppointmentStatus.Scheduled ? "bg-warning text-dark" : item.Status == AppointmentStatus.Completed ? "bg-success" : "bg-danger")">
                                        @Localizer[item.Status.ToString()]
                                    </span>
                                </td>
                                <td>@item.AppointmentDate.ToString("yyyy-MM-dd hh:mm")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@Localizer["Details"]</a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('@Localizer["ConfirmDelete"]');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">@Localizer["Empty"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
