@using PANDACLINIC.Application.DTOS.Appointment
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model AppointmentDetailDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-white py-4 border-0">
                    <h3 class="mb-0 fw-bold">@Localizer["Title"]</h3>
                </div>
                <div class="card-body p-4">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Pet"]</span>
                            <span class="fw-bold">@Model.AnimalName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Owner"]</span>
                            <span class="fw-bold">@Model.OwnerName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Type"]</span>
                            <span class="fw-bold">@Localizer[Model.TypeOfAppoinment.ToString()]</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Status"]</span>
                            <span class="badge @(Model.Status == AppointmentStatus.Scheduled ? "bg-warning text-dark" : Model.Status == AppointmentStatus.Completed ? "bg-success" : "bg-danger")">@Localizer[Model.Status.ToString()]</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Date"]</span>
                            <span class="fw-bold">@Model.AppointmentDate.ToString("yyyy-MM-dd hh:mm")</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center">
                    <a asp-action="MyAppointments" class="btn btn-link text-decoration-none text-dark">@Localizer["Back"]</a>
                </div>
            </div>
        </div>
    </div>
</div>
