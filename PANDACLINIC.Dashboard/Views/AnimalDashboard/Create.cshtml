@using PANDACLINIC.Application.DTOS.Animal
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model AnimalRequestDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">@Localizer["Title"]</h2>
                    <p class="text-muted text-center mb-4">@Localizer["Subtitle"]</p>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["Name"]</label>
                            <input asp-for="Name" class="form-control" placeholder="@Localizer["NamePlaceholder"]" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="AnimalType" class="form-label">@Localizer["AnimalType"]</label>
                            <select asp-for="AnimalType" class="form-select">
                                <option value="">@Localizer["ChooseType"]</option>
                                <option value="1">@Localizer["Dog"]</option>
                                <option value="2">@Localizer["Cat"]</option>
                                <option value="3">@Localizer["Birds"]</option>
                                <option value="4">@Localizer["Reptiles"]</option>
                            </select>
                            <span asp-validation-for="AnimalType" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">@Localizer["Image"]</label>
                            <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" />
                            <input type="hidden" asp-for="Imgageurl" />
                            <span asp-validation-for="ImageFile" class="text-danger small"></span>

                            <div class="mt-3 text-center">
                                <img id="preview" src="#" alt="Preview" class="img-thumbnail d-none" style="max-height: 200px; border-radius: 15px;" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
                            <i class="bi bi-plus-circle me-2"></i>@Localizer["Save"]
                        </button>
                    </form>
                </div>
            </div>
            <div class="text-center mt-3">
                <a asp-action="MyAnimals" class="text-decoration-none text-muted">@Localizer["MyAnimals"]</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const imageInput = document.getElementById('imageInput');
            const preview = document.getElementById('preview');
            if (!imageInput || !preview) return;

            imageInput.addEventListener('change', function () {
                const file = imageInput.files && imageInput.files[0];
                if (!file) {
                    preview.classList.add('d-none');
                    preview.removeAttribute('src');
                    return;
                }

                const objectUrl = URL.createObjectURL(file);
                preview.src = objectUrl;
                preview.classList.remove('d-none');
            });
        })();
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
