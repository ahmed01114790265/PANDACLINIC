@using PANDACLINIC.Application.DTOS.Animal
@model AnimalRequestDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">Regester Animal </h2>
                    <p class="text-muted text-center mb-4">Tell us about your furry friend.</p>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">NameofAnimal</label>
                            <input asp-for="Name" class="form-control" placeholder="Buddy" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="AnimalType" class="form-label">TypeofAnimal</label>
                            <select asp-for="AnimalType" class="form-select">
                                <option value="">-- Choose Type --</option>
                                <option value="1">كلب (Dog)</option>
                                <option value="2">قطة (Cat)</option>
                                <option value="3">عصافير زينة (Birds)</option>
                                <option value="4">سلاحف وزواحف (Reptiles)</option>
                            </select>
                            <span asp-validation-for="AnimalType" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">ImageofAnimal</label>
                            <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" />
                            <input type="hidden" asp-for="Imgageurl" />
                            <span asp-validation-for="ImageFile" class="text-danger small"></span>

                            <div class="mt-3 text-center">
                                <img id="preview" src="#" alt="Preview" class="img-thumbnail d-none" style="max-height: 200px; border-radius: 15px;" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
                            <i class="bi bi-plus-circle me-2"></i>Save
                        </button>
                    </form>
                </div>
            </div>
            <div class="text-center mt-3">
                <a asp-action="MyAnimals" class="text-decoration-none text-muted">MyAnimals</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const imageInput = document.getElementById('imageInput');
            const preview = document.getElementById('preview');
            if (!imageInput || !preview) return;

            imageInput.addEventListener('change', function () {
                const file = imageInput.files && imageInput.files[0];
                if (!file) {
                    preview.classList.add('d-none');
                    preview.removeAttribute('src');
                    return;
                }

                const objectUrl = URL.createObjectURL(file);
                preview.src = objectUrl;
                preview.classList.remove('d-none');
            });
        })();
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}