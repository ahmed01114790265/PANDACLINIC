@using PANDACLINIC.Application.DTOS.Order
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<OrderSummaryDto>

<div class="container-fluid py-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">@Localizer["Title"]</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Back"]</a>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>@Localizer["Order"]</th>
                    <th>@Localizer["Client"]</th>
                    <th>@Localizer["Phone"]</th>
                    <th>@Localizer["PaymentMethod"]</th>
                    <th>@Localizer["Total"]</th>
                    <th class="text-end">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Id</td>
                            <td>@order.ClientName</td>
                            <td>@order.ClientPhone</td>
                            <td>@Localizer[order.PaymentMethod]</td>
                            <td>@order.TotalAmount.ToString("0.##")</td>
                            <td class="text-end">
                                <form asp-action="Restore" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">@Localizer["Restore"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted">@Localizer["Empty"]</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
