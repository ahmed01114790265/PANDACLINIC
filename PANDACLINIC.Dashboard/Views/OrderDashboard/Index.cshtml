@using PANDACLINIC.Application.DTOS.Order
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<OrderSummaryDto>

@{
    var selectedStatus = ViewBag.SelectedStatus as OrderStatus?;
    var selectedPaymentStatus = ViewBag.SelectedPaymentStatus as PaymentStatus?;
    bool? clientConfirmed = ViewBag.SelectedClientConfirmed as bool?;
    bool paymentFollowUp = ViewBag.PaymentFollowUp is bool pf && pf;
}

<div class="container-fluid py-4 bg-white">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 border-bottom pb-3 gap-2">
        <h2 class="fw-bold text-dark mb-0"><i class="bi bi-receipt-cutoff me-2"></i>@Localizer["Title"]</h2>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" class="btn @(!selectedStatus.HasValue && !paymentFollowUp && !clientConfirmed.HasValue && !selectedPaymentStatus.HasValue ? "btn-dark" : "btn-outline-secondary")">@Localizer["All"]</a>
            <a asp-action="Index" asp-route-status="@OrderStatus.Pending" class="btn @(selectedStatus == OrderStatus.Pending ? "btn-dark" : "btn-outline-secondary")">@Localizer["PendingOrders"]</a>
            <a asp-action="Index" asp-route-paymentFollowUp="true" class="btn @(paymentFollowUp ? "btn-dark" : "btn-outline-secondary")">@Localizer["PaymentFollowUp"]</a>
            <a asp-action="RecycleBin" class="btn btn-outline-secondary">@Localizer["Archive"]</a>
        </div>
    </div>

    @if (paymentFollowUp)
    {
        <div class="alert alert-info">@Localizer["FollowUpInfo"]</div>
    }

    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-12 col-md-4">
                    <select name="status" class="form-select">
                        <option value="">@Localizer["AllOrderStatuses"]</option>
                        @foreach (var st in Enum.GetValues<OrderStatus>())
                        {
                            <option value="@st" selected="@(selectedStatus == st)">@Localizer[st.ToString()]</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <select name="paymentStatus" class="form-select">
                        <option value="">@Localizer["AllPaymentStatuses"]</option>
                        @foreach (var st in Enum.GetValues<PaymentStatus>())
                        {
                            <option value="@st" selected="@(selectedPaymentStatus == st)">@Localizer[st.ToString()]</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4 d-flex gap-2">
                    <select name="clientConfirmed" class="form-select">
                        <option value="">@Localizer["AllConfirmations"]</option>
                        <option value="true" selected="@(clientConfirmed == true)">@Localizer["Confirmed"]</option>
                        <option value="false" selected="@(clientConfirmed == false)">@Localizer["NotConfirmed"]</option>
                    </select>
                    <button type="submit" class="btn btn-dark">@Localizer["Filter"]</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Reset"]</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-light">
                <tr>
                    <th>@Localizer["Client"]</th>
                    <th>@Localizer["Phone"]</th>
                    <th>@Localizer["ClientConfirmed"]</th>
                    <th>@Localizer["PaymentMethod"]</th>
                    <th>@Localizer["PaymentStatus"]</th>
                    <th>@Localizer["OrderStatus"]</th>
                    <th>@Localizer["Total"]</th>
                    <th class="text-end">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ClientName</td>
                            <td>@item.ClientPhone</td>
                            <td>
                                <span class="badge @(item.IsClientConfirmed ? "bg-success" : "bg-secondary")">
                                    @Localizer[item.IsClientConfirmed ? "Confirmed" : "NotConfirmed"]
                                </span>
                            </td>
                            <td>@Localizer[string.IsNullOrWhiteSpace(item.PaymentMethod) ? "Unpaid" : item.PaymentMethod]</td>
                            <td>
                                <form asp-action="UpdatePaymentStatus" method="post" class="d-flex align-items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <select name="paymentStatus" class="form-select form-select-sm" onchange="this.form.submit()">
                                        @foreach (var st in Enum.GetValues<PaymentStatus>())
                                        {
                                            <option value="@st" selected="@(st == item.PaymentStatus)">@Localizer[st.ToString()]</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td>
                                <form asp-action="UpdateOrderStatus" method="post" class="d-flex align-items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                        @foreach (var st in Enum.GetValues<OrderStatus>())
                                        {
                                            <option value="@st" selected="@(st == item.Status)">@Localizer[st.ToString()]</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td>@item.TotalAmount.ToString("F2")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm"><i class="bi bi-eye"></i></a>
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmDelete('@item.Id')"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">@Localizer["Empty"]</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    function confirmDelete(id) {
        if (confirm('@Localizer["ConfirmDelete"]')) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteForm').submit();
        }
    }
</script>
