@using Microsoft.AspNetCore.Mvc.Localization
@using System.Globalization
@inject IViewLocalizer Localizer
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = isAuthenticated && User.IsInRole("Admin");

    var todayAppointmentsCount = 0;
    var ongoingHostingsCount = 0;
    var pendingOrdersCount = 0;
    var paymentFollowUpCount = 0;

    var culture = CultureInfo.CurrentUICulture;
    var isRtl = culture.TextInfo.IsRightToLeft;
    var lang = culture.TwoLetterISOLanguageName;
    var bootstrapHref = isRtl
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css"
        : Url.Content("~/lib/bootstrap/dist/css/bootstrap.min.css");
    var fontHref = isRtl
        ? "https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap"
        : "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<!DOCTYPE html>
<html lang="@lang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["DashboardTitle"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="@fontHref" rel="stylesheet">
    <link rel="stylesheet" href="@bootstrapHref" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PANDACLINIC.Dashboard.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="admin-header sticky-top">
        <nav class="navbar navbar-expand-xl py-3">
            <div class="container-fluid admin-nav-wrap">
                <a class="navbar-brand admin-brand" asp-controller="Home" asp-action="Index">
                    <span class="admin-brand-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                    <span>@Localizer["DashboardTitle"]</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="adminNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-xl-0 nav-cluster">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>@Localizer["Home"]</a>
                        </li>

                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AnimalDashboard" asp-action="Index"><i class="bi bi-heart me-1"></i>@Localizer["MyPets"]</a>
                            </li>

                            @if (isAdmin)
                            {
                                <li class="nav-item nav-kpi-item">
                                    <a class="nav-link nav-kpi-link" asp-controller="AppointmentDashboard" asp-action="Index">
                                        <i class="bi bi-calendar2-week me-1"></i>@Localizer["TodayAppointments"]
                                        <span id="navKpiToday" class="badge rounded-pill text-bg-primary">@todayAppointmentsCount</span>
                                    </a>
                                </li>
                                <li class="nav-item nav-kpi-item">
                                    <a class="nav-link nav-kpi-link" asp-controller="HostingDashboard" asp-action="Index">
                                        <i class="bi bi-house-heart me-1"></i>@Localizer["Hosting"]
                                        <span id="navKpiHosting" class="badge rounded-pill text-bg-success">@ongoingHostingsCount</span>
                                    </a>
                                </li>
                                <li class="nav-item nav-kpi-item">
                                    <a class="nav-link nav-kpi-link" asp-controller="OrderDashboard" asp-action="Index" asp-route-status="Pending" asp-route-paymentFollowUp="false">
                                        <i class="bi bi-bag-check me-1"></i>@Localizer["Pending"]
                                        <span id="navKpiPending" class="badge rounded-pill text-bg-warning">@pendingOrdersCount</span>
                                    </a>
                                </li>
                                <li class="nav-item nav-kpi-item">
                                    <a class="nav-link nav-kpi-link" asp-controller="OrderDashboard" asp-action="Index" asp-route-paymentFollowUp="true">
                                        <i class="bi bi-credit-card me-1"></i>@Localizer["Payments"]
                                        <span id="navKpiPayments" class="badge rounded-pill text-bg-danger">@paymentFollowUpCount</span>
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-xl-center user-cluster gap-2">
                        <li class="nav-item">
                            <form asp-controller="Localization" asp-action="SetLanguage" method="post" class="d-flex align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <label class="me-2 mb-0 fw-semibold">@Localizer["Language"]</label>
                                <select name="culture" class="form-select form-select-sm" onchange="this.form.submit()">
                                    <option value="ar" selected="@(lang == "ar")">@Localizer["Arabic"]</option>
                                    <option value="en" selected="@(lang == "en")">@Localizer["English"]</option>
                                </select>
                            </form>
                        </li>
                        @if (isAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-pill" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>@Localizer["ChangePassword"]</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                            <button type="submit" class="btn btn-danger btn-sm w-100">@Localizer["Logout"]</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary px-4" asp-controller="Account" asp-action="Login">@Localizer["Login"]</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid dashboard-shell px-3 px-lg-4">
        <div class="row g-3">
            @if (isAdmin)
            {
                <aside class="col-12 col-xl-2">
                    <div class="admin-aside card border-0 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="aside-title mb-3">@Localizer["Management"]</h6>
                            <nav class="aside-nav d-grid gap-2">
                                <a class="aside-link" asp-controller="AnimalDashboard" asp-action="Index"><i class="bi bi-paw me-2"></i><span>@Localizer["AllAnimals"]</span></a>
                                <a class="aside-link" asp-controller="AnimalDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-person-check me-2"></i><span>@Localizer["MyAnimals"]</span></a>
                                <a class="aside-link" asp-controller="AppointmentDashboard" asp-action="Index"><i class="bi bi-calendar-check me-2"></i><span>@Localizer["Appointments"]</span></a>
                                <a class="aside-link" asp-controller="AppointmentDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-calendar-plus me-2"></i><span>@Localizer["MyAppointments"]</span></a>
                                <a class="aside-link" asp-controller="HostingDashboard" asp-action="Index"><i class="bi bi-house-heart me-2"></i><span>@Localizer["Hostings"]</span></a>
                                <a class="aside-link" asp-controller="HostingDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-house-add me-2"></i><span>@Localizer["MyHostings"]</span></a>
                                <a class="aside-link" asp-controller="ProductDashboard" asp-action="Index"><i class="bi bi-box-seam me-2"></i><span>@Localizer["Products"]</span></a>
                                <a class="aside-link" asp-controller="Staff" asp-action="Index"><i class="bi bi-people me-2"></i><span>@Localizer["Staff"]</span></a>
                                <a class="aside-link" asp-controller="OrderDashboard" asp-action="Index"><i class="bi bi-receipt me-2"></i><span>@Localizer["OrdersReview"]</span></a>
                            </nav>
                        </div>
                    </div>
                </aside>
            }
            else if (isAuthenticated)
            {
                <aside class="col-12 col-xl-2">
                    <div class="admin-aside card border-0 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="aside-title mb-3">@Localizer["Management"]</h6>
                            <nav class="aside-nav d-grid gap-2">
                                <a class="aside-link" asp-controller="AnimalDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-paw me-2"></i><span>@Localizer["MyAnimals"]</span></a>
                                <a class="aside-link" asp-controller="AppointmentDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-calendar-check me-2"></i><span>@Localizer["MyAppointments"]</span></a>
                                <a class="aside-link" asp-controller="HostingDashboard" asp-action="Index" asp-route-mine="true"><i class="bi bi-house-heart me-2"></i><span>@Localizer["MyHostings"]</span></a>
                                <a class="aside-link" asp-controller="ProductDashboard" asp-action="Index"><i class="bi bi-box-seam me-2"></i><span>@Localizer["Products"]</span></a>
                            </nav>
                        </div>
                    </div>
                </aside>
            }

            <div class="@(isAuthenticated ? "col-12 col-xl-10" : "col-12")">
                <main role="main" class="py-3">
                    @if (TempData["SuccessMessage"] != null || TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i> @(TempData["SuccessMessage"] ?? TempData["Success"])
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <footer class="admin-footer">
        <div class="container-fluid text-center py-3">
            &copy; 2026 - @Localizer["DashboardTitle"]
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (isAdmin)
    {
        <script>
            (function () {
                const endpoint = '@Url.Action("NavbarKpis", "Home")';
                const ids = {
                    today: document.getElementById('navKpiToday'),
                    hosting: document.getElementById('navKpiHosting'),
                    pending: document.getElementById('navKpiPending'),
                    payments: document.getElementById('navKpiPayments')
                };

                async function refreshNavKpis() {
                    try {
                        const response = await fetch(endpoint, { cache: 'no-store' });
                        if (!response.ok) return;

                        const data = await response.json();
                        if (!data || data.isSuccess !== true) return;

                        if (ids.today) ids.today.textContent = data.todayAppointmentsCount ?? 0;
                        if (ids.hosting) ids.hosting.textContent = data.ongoingHostingsCount ?? 0;
                        if (ids.pending) ids.pending.textContent = data.pendingOrdersCount ?? 0;
                        if (ids.payments) ids.payments.textContent = data.paymentFollowUpCount ?? 0;
                    } catch {
                        // Keep existing numbers if refresh fails.
                    }
                }

                refreshNavKpis();
                setInterval(refreshNavKpis, 30000);
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
