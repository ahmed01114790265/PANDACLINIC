@model PANDACLINIC.Dashboard.Models.DashboardOverviewViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="dashboard-home">
    <section class="overview-hero mb-4">
        <div class="hero-content">
            <p class="hero-kicker mb-2">@Localizer["Kicker"]</p>
            <h1 class="hero-title mb-2">@Localizer["Welcome" , Model.GreetingName]</h1>
            <p class="hero-subtitle mb-0">@Localizer["Snapshot"]</p>
        </div>
        <div class="hero-meta text-muted small">
            <i class="bi bi-clock-history me-1"></i>
            @Localizer["Updated", Model.GeneratedAt.ToString("yyyy-MM-dd HH:mm")]
        </div>
    </section>

    <section class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-bold">@Localizer["QuickActions"]</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6 col-xl-3">
                    <a class="btn btn-outline-primary w-100" asp-controller="AppointmentDashboard" asp-action="Create">
                        <i class="bi bi-calendar-plus me-2"></i>@Localizer["CreateAppointment"]
                    </a>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <a class="btn btn-outline-success w-100" asp-controller="HostingDashboard" asp-action="Create">
                        <i class="bi bi-house-add me-2"></i>@Localizer["CreateHosting"]
                    </a>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <a class="btn btn-outline-secondary w-100" asp-controller="ProductDashboard" asp-action="Create">
                        <i class="bi bi-box-seam me-2"></i>@Localizer["AddProduct"]
                    </a>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <a class="btn btn-outline-info w-100" asp-controller="AnimalDashboard" asp-action="Create">
                        <i class="bi bi-paw me-2"></i>@Localizer["AddAnimal"]
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="kpi-grid mb-4">
        <article class="kpi-card">
            <div class="kpi-icon bg-soft-cyan"><i class="bi bi-heart-pulse"></i></div>
            <p class="kpi-label">@Localizer["AppointmentsToday"]</p>
            <h3 class="kpi-value">@Model.TodayAppointments</h3>
            <p class="kpi-foot">@Localizer["Scheduled", Model.ScheduledAppointments]</p>
        </article>

        <article class="kpi-card">
            <div class="kpi-icon bg-soft-blue"><i class="bi bi-house-heart"></i></div>
            <p class="kpi-label">@Localizer["CurrentHosting"]</p>
            <h3 class="kpi-value">@Model.OngoingHostings</h3>
            <p class="kpi-foot">@Localizer["TotalHostings", Model.TotalHostings]</p>
        </article>

        <article class="kpi-card">
            <div class="kpi-icon bg-soft-green"><i class="bi bi-box-seam"></i></div>
            <p class="kpi-label">@Localizer["ActiveProducts"]</p>
            <h3 class="kpi-value">@Model.ActiveProducts</h3>
            <p class="kpi-foot">@Localizer["LowStock", Model.LowStockProducts]</p>
        </article>

        <article class="kpi-card">
            <div class="kpi-icon bg-soft-amber"><i class="bi bi-receipt-cutoff"></i></div>
            <p class="kpi-label">@Localizer["PendingOrders"]</p>
            <h3 class="kpi-value">@Model.PendingOrders</h3>
            <p class="kpi-foot">@Localizer["TotalOrders", Model.TotalOrders]</p>
        </article>

        <article class="kpi-card">
            <div class="kpi-icon bg-soft-violet"><i class="bi bi-wallet2"></i></div>
            <p class="kpi-label">@Localizer["PaymentFollowUp"]</p>
            <h3 class="kpi-value">@Model.NewPayments</h3>
            <p class="kpi-foot">@Localizer["NeedConfirmation"]</p>
        </article>

        <article class="kpi-card">
            <div class="kpi-icon bg-soft-rose"><i class="bi bi-cash-stack"></i></div>
            <p class="kpi-label">@Localizer["CompletedRevenue"]</p>
            <h3 class="kpi-value">@Model.TotalRevenue.ToString("0.##") @Localizer["Currency"]</h3>
            <p class="kpi-foot">@Localizer["CompletedOrders", Model.CompletedOrders]</p>
        </article>
    </section>
</div>
