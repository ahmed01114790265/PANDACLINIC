@using PANDACLINIC.Application.DTOS.Appointment
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model AppointmentRequestDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">@Localizer["Title"]</h2>
                    <p class="text-muted text-center mb-4">@Localizer["Subtitle"]</p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="AnimalId" class="form-label">@Localizer["Animal"]</label>
                            <select asp-for="AnimalId" asp-items="ViewBag.Animals" class="form-select">
                                <option value="">@Localizer["SelectAnimal"]</option>
                            </select>
                            <span asp-validation-for="AnimalId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TypeOfAppoinment" class="form-label">@Localizer["Type"]</label>
                            <select asp-for="TypeOfAppoinment" asp-items="Html.GetEnumSelectList<AppointmentType>()" class="form-select"></select>
                            <span asp-validation-for="TypeOfAppoinment" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AppointmentDate" class="form-label">@Localizer["Date"]</label>
                            <input asp-for="AppointmentDate" type="datetime-local" class="form-control" value="@(Model.AppointmentDate == default ? string.Empty : Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm"))" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
                            <i class="bi bi-calendar-plus me-2"></i>@Localizer["Submit"]
                        </button>
                    </form>
                </div>
            </div>
            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none text-muted">@Localizer["Back"]</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
