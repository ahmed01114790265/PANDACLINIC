@using PANDACLINIC.Application.DTOS.Hosting
@using PANDACLINIC.Shared.Enums
@model HostingUpdateDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">Edit Hosting</h2>
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3"><label asp-for="AnimalId"></label><select asp-for="AnimalId" asp-items="ViewBag.Animals" class="form-select"><option value="">-- Select Animal --</option></select></div>
                        <input asp-for="RoomNumber" type="hidden" />
                        <div class="mb-3"><label asp-for="Status"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<HostingStayStatus>()" class="form-select"></select></div>
                        <div class="mb-3"><label asp-for="CheckInDate"></label><input asp-for="CheckInDate" type="datetime-local" class="form-control" value="@Model.CheckInDate.ToString("yyyy-MM-ddTHH:mm")" /></div>
                        <div class="mb-3"><label asp-for="CheckOutDate"></label><input asp-for="CheckOutDate" type="datetime-local" class="form-control" value="@(Model.CheckOutDate.HasValue ? Model.CheckOutDate.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)" /></div>
                        <button type="submit" class="btn btn-primary w-100">Save</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

