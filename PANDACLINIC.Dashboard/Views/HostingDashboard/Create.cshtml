@using PANDACLINIC.Application.DTOS.Hosting
@using PANDACLINIC.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model HostingRequestDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">@Localizer["Title"]</h2>
                    <p class="text-muted text-center mb-4">@Localizer["Subtitle"]</p>
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3"><label asp-for="AnimalId" class="form-label">@Localizer["Animal"]</label><select asp-for="AnimalId" asp-items="ViewBag.Animals" class="form-select"><option value="">@Localizer["SelectAnimal"]</option></select></div>
                        <input asp-for="RoomNumber" type="hidden" value="0" />
                        <div class="mb-3"><label asp-for="Status" class="form-label">@Localizer["Status"]</label><select asp-for="Status" asp-items="Html.GetEnumSelectList<HostingStayStatus>()" class="form-select"></select></div>
                        <div class="mb-3"><label asp-for="CheckInDate" class="form-label">@Localizer["CheckIn"]</label><input asp-for="CheckInDate" type="datetime-local" class="form-control" value="@Model.CheckInDate.ToString("yyyy-MM-ddTHH:mm")" /></div>
                        <div class="mb-3"><label asp-for="CheckOutDate" class="form-label">@Localizer["CheckOut"]</label><input asp-for="CheckOutDate" type="datetime-local" class="form-control" value="@(Model.CheckOutDate.HasValue ? Model.CheckOutDate.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)" /></div>
                        <button type="submit" class="btn btn-primary w-100">@Localizer["Submit"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
