@using PANDACLINIC.Application.DTOS.Hosting
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model HostingDetailDto

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-white py-4 border-0"><h3 class="mb-0 fw-bold">@Localizer["Title"]</h3></div>
                <div class="card-body p-4">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Animal"]</span><span class="fw-bold">@Model.AnimalName</span></li>
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Owner"]</span><span class="fw-bold">@Model.OwnerName</span></li>
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Room"]</span><span class="fw-bold">@Model.RoomNumber</span></li>
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Status"]</span><span class="fw-bold">@Localizer[Model.Status.ToString()]</span></li>
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["CheckIn"]</span><span class="fw-bold">@Model.CheckInDate.ToString("yyyy-MM-dd HH:mm")</span></li>
                        <li class="list-group-item d-flex justify-content-between"><span>@Localizer["CheckOut"]</span><span class="fw-bold">@(Model.CheckOutDate.HasValue ? Model.CheckOutDate.Value.ToString("yyyy-MM-dd HH:mm") : "-")</span></li>
                    </ul>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center"><a asp-action="Index" class="btn btn-link text-decoration-none text-dark">@Localizer["Back"]</a></div>
            </div>
        </div>
    </div>
</div>
